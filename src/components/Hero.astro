---
import { siteConfig } from "../config/site";
const { hero, business, trustBar } = siteConfig;
---

<section class="border-b-2 border-[color:var(--color-ink)]">
  <div class="max-w-[1240px] mx-auto px-5 lg:px-8 pt-14 lg:pt-20 pb-14 lg:pb-20">
    <div class="grid grid-cols-12 gap-6 lg:gap-10">
      <!-- left sidebar: eyebrow, phone, CTA column -->
      <aside class="col-span-12 lg:col-span-4 lg:order-2 flex flex-col">
        <div class="stamp mb-4">{hero.eyebrow}</div>

        <!-- Big phone treatment. The phone IS the hero. -->
        <a href={`tel:${business.phoneRaw}`} class="group block border-2 border-[color:var(--color-ink)] p-5 hover:bg-[color:var(--color-ink)] transition-colors">
          <div class="stamp-accent mb-2 group-hover:!text-[color:var(--color-paper-warm)] transition-colors">Call the shop</div>
          <div class="display-mixed text-[42px] lg:text-[52px] tabular-nums leading-none text-[color:var(--color-ink)] group-hover:text-[color:var(--color-paper)] transition-colors">
            {business.phone}
          </div>
          <div class="mt-4 text-sm text-[color:var(--color-ink-soft)] group-hover:text-[color:var(--color-paper-warm)] transition-colors">
            Anna picks up 7am–6pm. After hours: same number, straight to on-call.
          </div>
        </a>

        <!-- Secondary form CTA -->
        <a
          href="#contact"
          class="mt-4 block border-2 border-[color:var(--color-ink)] p-4 text-center display-mixed text-xl hover:bg-[color:var(--color-accent)] hover:text-[color:var(--color-paper)] hover:border-[color:var(--color-accent)] transition-colors"
        >
          {hero.secondaryCta}
        </a>

        <!-- Meta info strip -->
        <dl class="mt-6 space-y-1.5 text-sm">
          <div class="flex justify-between border-b border-[color:var(--color-ink)]/15 pb-1.5">
            <dt class="stamp">Trip fee</dt>
            <dd class="font-semibold tabular-nums">{business.tripFee}</dd>
          </div>
          <div class="flex justify-between border-b border-[color:var(--color-ink)]/15 pb-1.5">
            <dt class="stamp">License</dt>
            <dd class="font-semibold tabular-nums">{business.license}</dd>
          </div>
          <div class="flex justify-between border-b border-[color:var(--color-ink)]/15 pb-1.5">
            <dt class="stamp">Insured</dt>
            <dd class="font-semibold">{business.insurance}</dd>
          </div>
        </dl>
      </aside>

      <!-- main headline column -->
      <div class="col-span-12 lg:col-span-8 lg:order-1">
        <h1 class="display text-[64px] sm:text-[96px] lg:text-[144px] text-[color:var(--color-ink)]">
          {hero.headline}
        </h1>

        <p class="mt-8 text-[17px] lg:text-[18px] leading-[1.7] text-[color:var(--color-ink-soft)] max-w-[52ch]">
          {hero.body}
        </p>

        <!-- Areas served -->
        <div class="mt-10 pt-6 border-t-2 border-[color:var(--color-ink)]">
          <div class="stamp mb-3">Service area</div>
          <div class="flex flex-wrap gap-x-6 gap-y-2 display-mixed text-xl text-[color:var(--color-ink)]">
            {business.areasServed.map((area, i) => (
              <span class="flex items-baseline gap-2">
                {i > 0 && <span class="text-[color:var(--color-accent)]" aria-hidden="true">·</span>}
                <span>{area}</span>
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Trust bar — diagonal stripe top, condensed badges -->
  <div class="border-t-2 border-[color:var(--color-ink)]">
    <div class="diagonal-tape h-1.5"></div>
    <div class="bg-[color:var(--color-ink)] text-[color:var(--color-paper)]">
      <div class="max-w-[1240px] mx-auto px-5 lg:px-8 py-5">
        <ul class="flex flex-wrap items-center justify-between gap-x-6 gap-y-3 display-mixed text-lg lg:text-xl">
          {trustBar.map((item, i) => (
            <li class="flex items-baseline gap-4">
              {i > 0 && <span class="text-[color:var(--color-accent)]" aria-hidden="true">/</span>}
              <span class="tracking-wide">{item.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
